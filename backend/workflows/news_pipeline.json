        "jsCode": "const staticData = $getWorkflowStaticData('global');\nif (!staticData.summaryCount) staticData.summaryCount = 0;\nstaticData.summaryCount++;\nconst done = staticData.summaryCount >= 10;\nreturn [{ json: { done, count: staticData.summaryCount } }];"
      },
