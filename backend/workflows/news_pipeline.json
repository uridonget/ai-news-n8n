        "jsCode": "const staticData = $getWorkflowStaticData('global');\nstaticData.summaryCount = 0;\nreturn $input.all();"
      },
      "id": "21cc169a-943b-469e-9e4d-136cb6af4f38",
      "name": "카운트 초기화",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2208,
        1008
      ]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "9d6e5170-0a41-4c79-af38-b3047070efe0",
      "name": "Loop Over Items",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 1,
      "position": [
        2368,
        1008
      ]
    },
    {
      "parameters": {
        "jsCode": "const keyword  = $('Loop Over Items').item.json.keyword;\nconst allItems = $input.first().json.items || [];\n\nconst decodeEntities = s => s\n  .replace(/&quot;/g, '\"')\n  .replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<')\n  .replace(/&gt;/g, '>')\n  .replace(/&#39;/g, \"'\")\n  .replace(/&apos;/g, \"'\");\n\nconst naverItems = allItems.filter(i => i.link?.includes('n.news.naver.com'));\n\nif (naverItems.length === 0) {\n  return [{ json: { skip: true, keyword } }];\n}\n\nreturn naverItems.map(item => ({\n  json: {\n    skip: false,\n    keyword,\n    title:   decodeEntities(item.title.replace(/<[^>]+>/g, '').trim()),\n    url:     item.link,\n    pubDate: item.pubDate\n  }\n}));"
      },
      "id": "e4dfa213-2211-46b0-8202-d65f4100a878",
      "name": "링크 추출",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2688,
        1008
      ]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.skip }}",
              "value2": true
            }
          ]
        }
      },
      "id": "cea7c305-49e8-4df6-8d4a-40da918b70ea",
      "name": "스킵 체크",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        2848,
        1008
      ]
    },
    {
      "parameters": {
        "jsCode": "const originals = $('링크 추출').all();\n\nreturn $input.all().map((item, i) => {\n  const orig = originals[i]?.json || {};\n  const html = item.json.data || '';\n\n  const areaMatch = html.match(/id=[\"']dic_area[\"'][^>]*>([\\s\\S]*?)<\\/article>/);\n  let content = '';\n  if (areaMatch) {\n    content = areaMatch[1]\n      .replace(/<script[\\s\\S]*?<\\/script>/gi, '')\n      .replace(/<style[\\s\\S]*?<\\/style>/gi, '')\n      .replace(/<[^>]+>/g, ' ')\n      .replace(/\\s+/g, ' ')\n      .trim()\n      .slice(0, 2000);\n  }\n\n  const published_date = (() => {\n    try { return new Date(orig.pubDate).toLocaleDateString('sv-SE', { timeZone: 'Asia/Seoul' }); }\n    catch(e) { return new Date().toLocaleDateString('sv-SE', { timeZone: 'Asia/Seoul' }); }\n  })();\n\n  return {\n    json: {\n      keyword:        orig.keyword,\n      title:          orig.title,\n      url:            orig.url,\n      published_date,\n      content\n    }\n  };\n});"
      },
      "id": "e7a4984a-40e0-43c4-b667-358be6355d3d",
      "name": "본문 추출",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3168,
        1008
      ]
    },
    {
      "parameters": {
        "jsCode": "const articles = $('본문 추출').all();\nconst keyword  = $('Loop Over Items').item.json.keyword;\n\nconst articlesText = articles\n  .map((item, i) => `[기사 ${i + 1}]\\n${item.json.content}`)\n  .filter(t => t.trim().length > 15)\n  .join('\\n\\n');\n\nreturn [{ json: { keyword, articles_text: articlesText } }];"
      },
      "id": "3abf43ec-399c-435e-8204-47288e26e5c0",
      "name": "본문 취합",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3328,
        1008
      ]
    },
    {
      "parameters": {
        "jsCode": "const { keyword, articles_text } = $input.first().json;\n\nif (!articles_text || articles_text.trim().length < 100) {\n  return [{ json: { skip: true } }];\n}\n\nconst prompt = [\n  '당신은 전문 뉴스 애널리스트입니다.',\n  `아래는 '${keyword}'와 관련된 기사 본문입니다.`,\n  '',\n  '[기사 묶음]',\n  articles_text,\n  '',\n  '[작성 순서]',\n  '① 먼저 일반인이 알고 있기 어려운 전문 용어가 있다면 최대 3개를 선정하세요. 없다면 ### 용어 설명 ### 섹션은 비워두세요.',\n  '② 요약문을 작성할 때, 선정한 용어를 선정 시 결정한 표현 그대로 사용하세요.',\n  '③ 용어 설명 섹션에서는 ②에서 실제로 사용한 표현을 그대로 용어명으로 씁니다.',\n  '',\n  '[답변 규칙 - 반드시 준수]',\n  '- 아래 형식을 한 글자도 바꾸지 말고 그대로 사용하세요.',\n  '- ### 요약 ### 과 ### 용어 설명 ### 사이에 구분선(--)이나 다른 텍스트를 절대 넣지 마세요.',\n  '- 두 섹션 외의 어떤 머리말, 인사말, 부연 설명도 출력하지 마세요.',\n  '- 용어 설명의 용어명은 요약문에 등장하는 표현과 완전히 동일해야 합니다.',\n  '- 용어명에 괄호를 절대 사용하지 마세요. 영어 병기도 금지입니다. 예) **테이프 아웃:** 설명 (O) / **테이프 아웃(Tape-out):** 설명 (X) / **TC 본더(TC 본더):** 설명 (X)',\n  '- 요약은 사건의 배경, 현재 상황, 전망 순서로 작성하세요.',\n  '- 숫자나 고유명사 등 구체적인 정보를 포함하세요.',\n  '- 용어 설명은 해당 용어를 처음 듣는 사람도 이해할 수 있게 2~3문장으로 작성하세요.',\n  '- 요약문 안에 **볼드**, `코드`, _이탤릭_ 등 어떤 마크다운 서식도 사용하지 마세요. 순수 텍스트로만 작성하세요.',\n  '',\n  '[답변 형식]',\n  '### 요약 ###',\n  '(요약 내용만 작성, 3~5문장)',\n  '### 용어 설명 ###',\n  '- **용어명:** 설명'\n].join('\\n');\n\nreturn [{\n  json: {\n    contents: [{ parts: [{ text: prompt }] }]\n  }\n}];"
      },
      "id": "10971dd8-ae23-4fe9-ba8f-d8248861236b",
      "name": "요약 프롬프트 생성",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3488,
        1008
      ]
    },
    {
      "parameters": {
        "jsCode": "const text = $input.first().json.content.parts[0].text;\n\nconst summaryMatch = text.match(/#+\\s*요약\\s*#+\\s*\\n([\\s\\S]*?)(?=#+\\s*용어|$)/);\nconst termsMatch   = text.match(/#+\\s*용어\\s*설명?\\s*#+\\s*\\n([\\s\\S]*)$/);\n\nconst summary_text     = summaryMatch ? summaryMatch[1].trim() : text.trim();\nconst term_explanation = termsMatch   ? termsMatch[1].trim()   : '';\n\nreturn [{ json: { summary_text, term_explanation } }];"
      },
      "id": "7ee3a51d-0c73-417e-ae9b-4c0ca388ff4a",
      "name": "요약 파싱",
